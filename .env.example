# ──────────────────────────────────────────────────────────────────────────────
# DepoStock API — Variables de entorno
# Copiar a .env y completar antes de ejecutar.
# ──────────────────────────────────────────────────────────────────────────────

# CUIT del depositario fiscal (sin guiones)
CUIT=20123456789

# Rutas a los archivos de certificado digital y clave privada
# generados para operar con AFIP/ARCA (formato PEM)
CERT_PATH=/ruta/al/certificado.crt
KEY_PATH=/ruta/a/la/clave_privada.key

# Ambiente: false = homologación/testing  |  true = producción
PRODUCTION=false

# Tipo de agente y rol (siempre "DEPO" para depositarios fiscales)
TIPO_AGENTE=DEPO
ROL=DEPO

# Clave para proteger los endpoints REST (dejar vacío para deshabilitar)
API_KEY=cambia-esta-clave-secreta
